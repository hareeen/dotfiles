{
  "base_keymap": "VSCode",
  "autosave": "on_focus_change",
  "ui_font_size": 15,
  "buffer_font_size": 12,
  "buffer_font_family": "FiraCode Nerd Font",
  "theme": {
    "mode": "system",
    "light": "Atelier Cave Light",
    "dark": "Atelier Cave Dark"
  },
  "languages": {
    "Python": {
      "language_servers": ["ruff", "pyright"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports.ruff": true,
            "source.fixAll.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  }
}
